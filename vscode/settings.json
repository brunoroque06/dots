{
  "[csharp]": {
    "editor.defaultFormatter": "csharpier.csharpier-vscode"
  },
  "[css][dockercompose][html][javascript][json][jsonc][markdown][scss][typescript][yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[csv]": {
    "editor.stickyScroll.enabled": true
  },
  "[python]": {
    "diffEditor.ignoreTrimWhitespace": true,
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "breadcrumbs.enabled": false,
  "chat.agent.maxRequests": 64,
  "chat.editor.wordWrap": "on",
  "chat.mcp.gallery.enabled": true,
  "chat.planAgent.defaultModel": "Claude Opus 4.6 (copilot)",
  "chat.plugins.enabled": true,
  "chat.plugins.marketplaces": ["dotnet/skills"],
  "chat.tools.compressOutput.enabled": true,
  "containers.containerClient": "com.microsoft.visualstudio.containers.podman",
  "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.podmancompose",
  "dance.menus": {
    "goto": {
      "items": {
        "f": {
          "command": "editor.action.openLink",
          "text": "to url"
        },
        "i": {
          "command": "editor.action.goToImplementation",
          "text": "to implementation"
        },
        "R": {
          "command": "editor.showCallHierarchy",
          "text": "to call hierarchy"
        },
        "w": {
          "command": "dance.seek.wordLabel",
          "text": "to word"
        }
      }
    }
  },
  "dance.modes": {
    "helix/normal": {
      "decorations": {
        "backgroundColor": "none"
      }
    }
  },
  "dance.smartCase": true,
  "debug.allowBreakpointsEverywhere": true,
  "debug.inlineValues": "on",
  "debug.internalConsoleOptions": "neverOpen",
  "debug.toolBarLocation": "docked",
  "diffEditor.experimental.showMoves": true,
  "diffEditor.hideUnchangedRegions.contextLineCount": 8,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.renderSideBySide": false,
  "dotnet.codeLens.enableReferencesCodeLens": false,
  "dotnet.formatting.organizeImportsOnFormat": true,
  "dotnet.inlayHints.enableInlayHintsForLiteralParameters": true,
  "dotnet.inlayHints.enableInlayHintsForOtherParameters": true,
  "dotnet.inlayHints.enableInlayHintsForParameters": true,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sort.json": "explicit"
  },
  "editor.cursorBlinking": "solid",
  "editor.cursorSurroundingLines": 4,
  "editor.cursorWidth": 2,
  "editor.experimental.preferTreeSitter.css": true,
  "editor.experimental.preferTreeSitter.ini": true,
  "editor.experimental.preferTreeSitter.regex": true,
  "editor.experimental.preferTreeSitter.typescript": false,
  "editor.fontFamily": "MPLUS1Code-Regular",
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.guides.bracketPairs": true,
  "editor.inlineSuggest.enabled": true,
  "editor.lineHeight": 1.3,
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "trailing",
  "editor.scrollbar.verticalScrollbarSize": 8,
  "editor.suggestSelection": "first",
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "explorer.confirmDragAndDrop": false,
  "explorer.openEditors.sortOrder": "alphabetical",
  "explorer.openEditors.visible": 1,
  "extensions.ignoreRecommendations": true,
  "files.autoSave": "afterDelay",
  "files.simpleDialog.enable": true,
  "files.trimTrailingWhitespace": true,
  "git.blame.editorDecoration.enabled": false,
  "git.blame.ignoreWhitespace": true,
  "git.detectWorktrees": true,
  "git.detectWorktreesLimit": 8,
  "git.openRepositoryInParentFolders": "prompt",
  "github.copilot.enable": {
    "*": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.fixes": true,
  "inlineChat.defaultModel": "Claude Opus 4.6 (copilot)",
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.parameterTypes.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "markdown.preview.fontFamily": "SF Pro Rounded",
  "mssql.defaultQueryResultsViewMode": "Text",
  "mssql.format.datatypeCasing": "lowercase",
  "mssql.format.keywordCasing": "lowercase",
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.inlayHints.callArgumentNames": "partial",
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.pytestParameters": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.languageServerMode": "full",
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.typeEvaluation.strictDictionaryInference": true,
  "python.analysis.typeEvaluation.strictListInference": true,
  "python.analysis.typeEvaluation.strictSetInference": true,
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
  "python.languageServer": "Pylance",
  "python.terminal.activateEnvironment": false,
  "python.testing.pytestEnabled": true,
  "ruff.organizeImports": true,
  "scm.alwaysShowRepositories": true,
  "settingsSync.ignoredSettings": [
    "editor.fontFamily",
    "markdown.preview.fontFamily"
  ],
  "terminal.integrated.defaultLocation": "editor",
  "terminal.integrated.defaultProfile.osx": "elvish",
  "terminal.integrated.defaultProfile.windows": "pwsh",
  "terminal.integrated.macOptionIsMeta": true,
  "terminal.integrated.profiles.osx": {
    "elvish": {
      "path": "/opt/homebrew/bin/elvish"
    }
  },
  "terminal.integrated.profiles.windows": {
    "pwsh": {
      "path": "C:/Program Files/PowerShell/7/pwsh.exe"
    }
  },
  "terraform.mcp.server.enable": false,
  "tinymist.formatterMode": "typstyle",
  "window.commandCenter": false,
  "window.title": "${activeEditorLong}${separator}${rootPath}",
  "window.zoomLevel": 0.8,
  "workbench.activityBar.compact": true,
  "workbench.activityBar.location": "bottom",
  "workbench.browser.showInTitleBar": false,
  "workbench.colorTheme": "Light 2026",
  "workbench.editor.enablePreview": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 8,
  "workbench.editor.revealIfOpen": false,
  "workbench.editor.showTabs": "single",
  "workbench.editor.useModal": "off",
  "workbench.layoutControl.enabled": false,
  "workbench.notifications.position": "top-right",
  "workbench.notifications.showInTitleBar": false,
  "workbench.panel.showLabels": false,
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always"
}
