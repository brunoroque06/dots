command = /opt/homebrew/bin/elvish
cursor-style = block
cursor-style-blink = false
font-family = M Plus 1 Code
font-size = 14
font-style = Regular
font-style-bold = Medium
macos-option-as-alt = true
macos-titlebar-style = tabs
quick-terminal-position = right
quick-terminal-size = 33%,100%
shell-integration-features = no-cursor
unfocused-split-opacity = 1
theme = GitHub Light Default
window-padding-x = 10
window-padding-y = 10
# window-save-state = never

keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
keybind = super+shift+.=move_tab:1
keybind = super+shift+,=move_tab:-1
keybind = global:super+i=toggle_quick_terminal
